ENVIRONMENT=production
PROJECT_NAME=Zivolf API
PROJECT_VERSION=1.0.0

# Never use sqlite in production
DATABASE_URL=postgresql+psycopg2://zivolf_user:change_me@127.0.0.1:5432/zivolf_prod

SECRET_KEY=change-me-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

FRONTEND_URL=https://zivolf.com
CORS_ORIGINS=https://zivolf.com,https://www.zivolf.com

OPENROUTER_API_KEY=replace-with-production-openrouter-key
OPENROUTER_MODEL=deepseek/deepseek-v3.2-exp
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_HTTP_REFERER=https://zivolf.com
OPENROUTER_APP_TITLE=Zivolf AI Assistant
OPENROUTER_TIMEOUT_SECONDS=30

NEXT_PUBLIC_API_BASE_URL=https://api.zivolf.com