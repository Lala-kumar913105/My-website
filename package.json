{
  "name": "my-website-root",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm --prefix frontend run dev --",
    "dev:frontend": "npm --prefix frontend run dev --",
    "dev:stop": "npm --prefix frontend run dev:stop",
    "dev:restart": "npm --prefix frontend run dev:restart --",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix frontend run start",
    "dev:root": "node -e \"console.error('Root Next.js runtime is disabled. Use frontend as source-of-truth: npm --prefix frontend run dev'); process.exit(1)\""
  },
  "dependencies": {},
  "devDependencies": {}
}
